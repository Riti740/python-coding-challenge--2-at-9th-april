      "source": [
        "#DUPLICATE CHARACTERS\n",
        "s = input()\n",
        "dup = set()\n",
        "seen = set()\n",
        "for i in s:\n",
        "    if i in seen:\n",
        "        dup.add(i)\n",
        "    else:\n",
        "        seen.add(i)\n",
        "print(*dup)"
      ],
